{
  "name": "backscroll",
  "version": "0.1.0",
  "description": "A time machine for your terminal — records every command AND its output into a local, searchable store.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "bsc": "dist/cli.js"
  },
  "files": [
    "dist",
    "dist-ui",
    "scripts/postinstall.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\" && npm run build:ui",
    "dev": "tsc -w -p tsconfig.json",
    "dev:ui": "vite --config ui/vite.config.ts",
    "build:ui": "vite build --config ui/vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^12.1.0",
    "node-pty": "^1.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-virtual": "^3.11.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.0.7"
  }
}
